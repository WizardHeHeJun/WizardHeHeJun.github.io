---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HeroImage from '../components/HeroImage.astro';
import TableOfContents from '../components/TableOfContents.astro';

type PostRef = { id: string; title: string } | null;
type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	wordCount?: number;
	readingTime?: number;
	prevPost?: PostRef;
	nextPost?: PostRef;
};

const {
	slug,
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	tags = [],
	wordCount,
	readingTime,
	prevPost = null,
	nextPost = null,
} = Astro.props;
---

<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: 100%;
				margin: 0;
				padding: 2em 1em;
				background: transparent;
				backdrop-filter: none;
				-webkit-backdrop-filter: none;
				border: none;
				border-radius: 0;
				box-shadow: none;
			}
			.hero-image {
				width: min(1100px, 100% - 2em);
				margin: 0 auto 1em;
				aspect-ratio: 1020 / 510;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 8px 32px rgba(31, 38, 135, 0.2);
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
			}
			.prose {
				width: min(840px, 100% - 2em);
				margin: auto;
				padding: 2.5em 2.4em;
				color: rgb(var(--gray-dark));
				background: rgba(255, 255, 255, 0.6);
				backdrop-filter: blur(18px) saturate(180%);
				-webkit-backdrop-filter: blur(18px) saturate(180%);
				border: 1px solid rgba(255, 255, 255, 0.45);
				border-radius: 18px;
				box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
			}
			@media (min-width: 1400px) {
				.hero-image {
					width: min(1280px, 100% - 4em);
				}
				.prose {
					width: min(960px, 100% - 4em);
					padding: 3em 3em;
				}
			}
			@media (min-width: 1800px) {
				.hero-image {
					width: min(1440px, 100% - 6em);
				}
				.prose {
					width: min(1100px, 100% - 6em);
					padding: 3em 3.5em;
				}
			}
			@media (max-width: 640px) {
				.hero-image {
					width: min(1100px, 100% - 0.8em);
				}
				.prose {
					width: min(840px, 100% - 0.8em);
					padding: 1.6em 1.1em;
				}
				.comments-wrap {
					width: min(840px, 100% - 0.8em);
				}
			}
			.comments-wrap {
				width: min(840px, 100% - 2em);
				margin: 2em auto 0;
			}
			@media (min-width: 1400px) {
				.comments-wrap {
					width: min(960px, 100% - 4em);
				}
			}
			@media (min-width: 1800px) {
				.comments-wrap {
					width: min(1100px, 100% - 6em);
				}
			}
			.title {
				margin-bottom: 1em;
				padding: 0.5em 0 1em;
				text-align: center;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
			.stats {
				font-size: 0.9em;
				color: rgb(var(--gray));
			}
			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6em;
				justify-content: center;
				margin-top: 0.6em;
			}
			.meta-row a {
				display: inline-block;
				padding: 0.15em 0.7em;
				background: rgba(35, 55, 255, 0.08);
				border: 1px solid rgba(35, 55, 255, 0.18);
				border-radius: 999px;
				font-size: 0.85em;
				color: var(--accent);
				text-decoration: none;
				transition: background 0.15s ease;
			}
			.meta-row a:hover {
				background: rgba(35, 55, 255, 0.16);
			}
			.meta-row .cat {
				background: rgba(255, 200, 100, 0.25);
				border-color: rgba(255, 180, 80, 0.5);
				color: #b8860b;
				font-weight: 600;
			}
			.meta-row .cat:hover {
				background: rgba(255, 200, 100, 0.45);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && slug && (
						<HeroImage slug={slug} src={heroImage} width={1020} height={510} loading="eager" />
					)}
				</div>
				<TableOfContents prevPost={prevPost} nextPost={nextPost} />
				<div class="prose" data-pagefind-body>
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{wordCount !== undefined && readingTime !== undefined && (
								<span class="stats"> · {wordCount} 字 · {readingTime} 分钟阅读</span>
							)}
							{
								updatedDate && (
									<div class="last-updated-on">
										最后更新于 <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						{
							(category || tags.length > 0) && (
								<div class="meta-row">
									{category && (
										<a class="cat" href={`/categories/${encodeURIComponent(category)}/`}>
											{category}
										</a>
									)}
									{tags.map((t) => (
										<a href={`/tags/${encodeURIComponent(t)}/`}>#{t}</a>
									))}
								</div>
							)
						}
						<hr />
					</div>
					<slot />
				</div>
			</article>
			<div class="comments-wrap">
				<Comments mapping="pathname" />
			</div>
		</main>
		<Footer />

		<script is:inline>
			(function () {
				function initSpoilers() {
					document.querySelectorAll('.prose .spoiler').forEach((el) => {
						el.addEventListener('click', () => el.classList.add('revealed'));
						el.addEventListener('keydown', (e) => {
							if (e.key === 'Enter' || e.key === ' ') {
								e.preventDefault();
								el.classList.add('revealed');
							}
						});
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', initSpoilers);
				} else {
					initSpoilers();
				}
			})();
		</script>

		<script>
			// Mermaid lazy load —— 仅当本文有 .mermaid 块时才载 mermaid.js（~700KB）
			// 渲染完成后调用 window.__enhanceMermaid?.() 注入「点击放大」按钮（见后续 inline script）
			if (document.querySelector('.prose .mermaid')) {
				import('mermaid').then(async ({ default: mermaid }) => {
					mermaid.initialize({
						startOnLoad: false,
						theme: 'base',
						themeVariables: {
							fontFamily: "'LXGW WenKai Screen', 'PingFang SC', sans-serif",
							primaryColor: '#dde7ff',
							primaryTextColor: '#222939',
							primaryBorderColor: '#2337ff',
							lineColor: '#66ccff',
							secondaryColor: '#ffd1e4',
							tertiaryColor: '#f0f6ff',
							noteBkgColor: '#fff7e6',
							noteBorderColor: '#b8860b',
						},
					});
					await mermaid.run({ querySelector: '.prose .mermaid' });
					// @ts-expect-error 在后续 <script is:inline> 中挂到 window 上
					window.__enhanceMermaid?.();
				});
			}
		</script>

		<script is:inline>
			// 正文 figure 点击 → lightbox（仿 macOS 预览：右侧工具栏 + 双击/滚轮缩放 + 拖拽平移）
			// portal 三件（backdrop / figure / toolbar）到 body 避开 .prose 的 stacking trap
			(function () {
				const ICON = (paths) =>
					`<svg viewBox="0 0 20 20" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
				const ZOOM_IN = ICON('<circle cx="9" cy="9" r="6"/><line x1="13.5" y1="13.5" x2="17.5" y2="17.5"/><line x1="9" y1="6" x2="9" y2="12"/><line x1="6" y1="9" x2="12" y2="9"/>');
				const ZOOM_OUT = ICON('<circle cx="9" cy="9" r="6"/><line x1="13.5" y1="13.5" x2="17.5" y2="17.5"/><line x1="6" y1="9" x2="12" y2="9"/>');
				const FIT = ICON('<polyline points="3 7 3 3 7 3"/><polyline points="17 7 17 3 13 3"/><polyline points="17 13 17 17 13 17"/><polyline points="3 13 3 17 7 17"/>');
				const CLOSE = ICON('<line x1="5" y1="5" x2="15" y2="15"/><line x1="15" y1="5" x2="5" y2="15"/>');

				function init() {
					document.querySelectorAll('.prose figure.prose-figure').forEach((fig) => {
						if (fig.dataset.lightboxBound) return;
						fig.dataset.lightboxBound = '1';
						fig.addEventListener('click', (e) => {
							e.preventDefault();
							openLightbox(fig);
						});
					});
				}

				function openLightbox(fig) {
					// 1. backdrop（暗背景 + click 关闭）
					const backdrop = document.createElement('div');
					backdrop.className = 'lightbox-backdrop';

					// 2. figure（clone 原 figure）
					const clone = fig.cloneNode(true);
					clone.classList.remove('prose-figure');
					clone.classList.add('prose-figure-fullscreen');
					const img = clone.querySelector('img');

					// 3. toolbar（右侧工具栏）
					const toolbar = document.createElement('div');
					toolbar.className = 'lightbox-toolbar';
					toolbar.innerHTML = `
						<button data-action="zoom-in" aria-label="放大" title="放大">${ZOOM_IN}</button>
						<span class="lightbox-zoom-level">100%</span>
						<button data-action="zoom-out" aria-label="缩小" title="缩小">${ZOOM_OUT}</button>
						<button data-action="fit" aria-label="重置" title="重置">${FIT}</button>
						<button data-action="close" aria-label="关闭" title="关闭 (ESC)">${CLOSE}</button>
					`;
					const zoomLabel = toolbar.querySelector('.lightbox-zoom-level');

					// 缩放状态
					let scale = 1,
						tx = 0,
						ty = 0;
					const MIN = 0.25,
						MAX = 6;
					const apply = () => {
						img.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
						zoomLabel.textContent = Math.round(scale * 100) + '%';
						img.classList.toggle('is-zoomed', scale > 1.05);
					};
					const setScale = (next, originX, originY) => {
						const prev = scale;
						scale = Math.max(MIN, Math.min(MAX, next));
						if (originX !== undefined) {
							// 以鼠标位置为原点缩放
							const rect = img.getBoundingClientRect();
							const cx = rect.left + rect.width / 2;
							const cy = rect.top + rect.height / 2;
							const k = scale / prev - 1;
							tx -= (originX - cx) * k;
							ty -= (originY - cy) * k;
						}
						apply();
					};

					// 工具栏点击
					toolbar.addEventListener('click', (e) => {
						const btn = e.target.closest('button');
						if (!btn) return;
						const a = btn.dataset.action;
						if (a === 'zoom-in') setScale(scale * 1.25);
						else if (a === 'zoom-out') setScale(scale / 1.25);
						else if (a === 'fit') {
							scale = 1;
							tx = 0;
							ty = 0;
							apply();
						} else if (a === 'close') close();
					});

					// 滚轮缩放
					img.addEventListener('wheel', (e) => {
						e.preventDefault();
						const delta = e.deltaY < 0 ? 1.1 : 1 / 1.1;
						setScale(scale * delta, e.clientX, e.clientY);
					}, { passive: false });

					// 双击切换
					img.addEventListener('dblclick', (e) => {
						e.preventDefault();
						if (scale > 1.05) {
							scale = 1;
							tx = 0;
							ty = 0;
							apply();
						} else {
							setScale(2.5, e.clientX, e.clientY);
						}
					});

					// 拖拽平移（zoom > 1 时）
					let dragging = false,
						startX = 0,
						startY = 0;
					img.addEventListener('mousedown', (e) => {
						if (scale <= 1.05) return;
						e.preventDefault();
						dragging = true;
						startX = e.clientX - tx;
						startY = e.clientY - ty;
						img.classList.add('is-dragging');
					});
					const onMove = (e) => {
						if (!dragging) return;
						tx = e.clientX - startX;
						ty = e.clientY - startY;
						apply();
					};
					const onUp = () => {
						if (!dragging) return;
						dragging = false;
						img.classList.remove('is-dragging');
					};
					document.addEventListener('mousemove', onMove);
					document.addEventListener('mouseup', onUp);

					// 阻止 figure 内 click 冒泡到 backdrop
					clone.addEventListener('click', (e) => e.stopPropagation());

					backdrop.addEventListener('click', close);

					// ESC 关闭
					const onKey = (e) => {
						if (e.key === 'Escape') close();
					};
					document.addEventListener('keydown', onKey);

					document.body.appendChild(backdrop);
					document.body.appendChild(clone);
					document.body.appendChild(toolbar);
					document.body.classList.add('figure-lightbox-open');

					function close() {
						backdrop.remove();
						clone.remove();
						toolbar.remove();
						document.body.classList.remove('figure-lightbox-open');
						document.removeEventListener('keydown', onKey);
						document.removeEventListener('mousemove', onMove);
						document.removeEventListener('mouseup', onUp);
					}
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();
		</script>

		<script is:inline>
			// Mermaid lightbox：mermaid.run() 完成后调用 window.__enhanceMermaid()
			// 给每个 .mermaid-figure 注入右上角放大按钮，并支持点击 SVG 进入全屏 lightbox
			// 复用 figure-lightbox 同款工具栏与样式（lightbox-backdrop / lightbox-toolbar / figure-lightbox-open）
			(function () {
				const ICON = (paths) =>
					`<svg viewBox="0 0 20 20" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
				const ZOOM_IN = ICON('<circle cx="9" cy="9" r="6"/><line x1="13.5" y1="13.5" x2="17.5" y2="17.5"/><line x1="9" y1="6" x2="9" y2="12"/><line x1="6" y1="9" x2="12" y2="9"/>');
				const ZOOM_OUT = ICON('<circle cx="9" cy="9" r="6"/><line x1="13.5" y1="13.5" x2="17.5" y2="17.5"/><line x1="6" y1="9" x2="12" y2="9"/>');
				const FIT = ICON('<polyline points="3 7 3 3 7 3"/><polyline points="17 7 17 3 13 3"/><polyline points="17 13 17 17 13 17"/><polyline points="3 13 3 17 7 17"/>');
				const CLOSE = ICON('<line x1="5" y1="5" x2="15" y2="15"/><line x1="15" y1="5" x2="5" y2="15"/>');
				function bind(fig) {
					if (fig.dataset.lightboxBound) return;
					fig.dataset.lightboxBound = '1';
					// 整图可点（含 padding 区域）—— 桌面/移动统一交互，无 hover 依赖
					fig.addEventListener('click', (e) => {
						e.preventDefault();
						openLightbox(fig);
					});
				}

				function enhance() {
					document.querySelectorAll('.prose .mermaid-figure').forEach((fig) => {
						if (fig.dataset.lightboxBound) return;
						const svg = fig.querySelector('svg');
						if (svg) {
							bind(fig);
							return;
						}
						// mermaid v11 渲染复杂图时 SVG 注入是异步的，run() resolve 后可能还未就绪
						// 用 MutationObserver 等 SVG 出现（兜底任何时序问题）
						const observer = new MutationObserver(() => {
							if (fig.querySelector('svg')) {
								observer.disconnect();
								bind(fig);
							}
						});
						observer.observe(fig, { childList: true, subtree: true });
						// 安全网：10 秒后停止观察，避免 mermaid 真的失败时挂泄漏
						setTimeout(() => observer.disconnect(), 10000);
					});
				}

				function openLightbox(fig) {
					const origSvg = fig.querySelector('svg');
					if (!origSvg) return;

					// 1. backdrop
					const backdrop = document.createElement('div');
					backdrop.className = 'lightbox-backdrop';

					// 2. 容器 + frame（frame 承接 transform，让 SVG 和它的白色画框一起缩放）
					const container = document.createElement('div');
					container.className = 'mermaid-lightbox';
					const frame = document.createElement('div');
					frame.className = 'mermaid-lightbox-frame';
					const svgClone = origSvg.cloneNode(true);
					// 关键：保留 id —— mermaid 注入的 <style> 用 #mermaid-xxx 作用域，
					// 清掉 id 会让所有 .node / .cluster / .edgePath 选择器失效，节点退回默认黑色
					// 清掉 mermaid 注入的 inline style 与 width/height 属性，强制按 viewBox 撑满 frame
					svgClone.removeAttribute('style');
					svgClone.setAttribute('width', '100%');
					svgClone.setAttribute('height', '100%');
					svgClone.setAttribute('preserveAspectRatio', 'xMidYMid meet');
					frame.appendChild(svgClone);
					container.appendChild(frame);

					// 3. toolbar
					const toolbar = document.createElement('div');
					toolbar.className = 'lightbox-toolbar';
					toolbar.innerHTML = `
						<button data-action="zoom-in" aria-label="放大" title="放大">${ZOOM_IN}</button>
						<span class="lightbox-zoom-level">100%</span>
						<button data-action="zoom-out" aria-label="缩小" title="缩小">${ZOOM_OUT}</button>
						<button data-action="fit" aria-label="重置" title="重置">${FIT}</button>
						<button data-action="close" aria-label="关闭" title="关闭 (ESC)">${CLOSE}</button>
					`;
					const zoomLabel = toolbar.querySelector('.lightbox-zoom-level');

					let scale = 1,
						tx = 0,
						ty = 0;
					const MIN = 0.25,
						MAX = 8;
					const apply = () => {
						frame.style.transform = `translate(${tx}px, ${ty}px) scale(${scale})`;
						zoomLabel.textContent = Math.round(scale * 100) + '%';
						frame.classList.toggle('is-zoomed', scale > 1.05);
					};
					const setScale = (next, originX, originY) => {
						const prev = scale;
						scale = Math.max(MIN, Math.min(MAX, next));
						if (originX !== undefined) {
							const rect = frame.getBoundingClientRect();
							const cx = rect.left + rect.width / 2;
							const cy = rect.top + rect.height / 2;
							const k = scale / prev - 1;
							tx -= (originX - cx) * k;
							ty -= (originY - cy) * k;
						}
						apply();
					};

					toolbar.addEventListener('click', (e) => {
						const b = e.target.closest('button');
						if (!b) return;
						const a = b.dataset.action;
						if (a === 'zoom-in') setScale(scale * 1.25);
						else if (a === 'zoom-out') setScale(scale / 1.25);
						else if (a === 'fit') {
							scale = 1;
							tx = 0;
							ty = 0;
							apply();
						} else if (a === 'close') close();
					});

					// 滚轮缩放（以鼠标为原点）
					frame.addEventListener(
						'wheel',
						(e) => {
							e.preventDefault();
							const delta = e.deltaY < 0 ? 1.1 : 1 / 1.1;
							setScale(scale * delta, e.clientX, e.clientY);
						},
						{ passive: false }
					);

					// 双击切换 1x / 2.5x
					frame.addEventListener('dblclick', (e) => {
						e.preventDefault();
						if (scale > 1.05) {
							scale = 1;
							tx = 0;
							ty = 0;
							apply();
						} else {
							setScale(2.5, e.clientX, e.clientY);
						}
					});

					// 拖拽平移
					let dragging = false,
						startX = 0,
						startY = 0;
					frame.addEventListener('mousedown', (e) => {
						if (scale <= 1.05) return;
						e.preventDefault();
						dragging = true;
						startX = e.clientX - tx;
						startY = e.clientY - ty;
						frame.classList.add('is-dragging');
					});
					const onMove = (e) => {
						if (!dragging) return;
						tx = e.clientX - startX;
						ty = e.clientY - startY;
						apply();
					};
					const onUp = () => {
						if (!dragging) return;
						dragging = false;
						frame.classList.remove('is-dragging');
					};
					document.addEventListener('mousemove', onMove);
					document.addEventListener('mouseup', onUp);

					frame.addEventListener('click', (e) => e.stopPropagation());
					backdrop.addEventListener('click', close);

					const onKey = (e) => {
						if (e.key === 'Escape') close();
					};
					document.addEventListener('keydown', onKey);

					document.body.appendChild(backdrop);
					document.body.appendChild(container);
					document.body.appendChild(toolbar);
					document.body.classList.add('figure-lightbox-open');

					function close() {
						backdrop.remove();
						container.remove();
						toolbar.remove();
						document.body.classList.remove('figure-lightbox-open');
						document.removeEventListener('keydown', onKey);
						document.removeEventListener('mousemove', onMove);
						document.removeEventListener('mouseup', onUp);
					}
				}

				window.__enhanceMermaid = enhance;

				// DOM 就绪即跑一次：enhance 内 MutationObserver 兜底等 SVG 注入
				// 路径双保险——mermaid.run() resolve 时再调用一次也只会因 dataset 去重而 no-op
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', enhance);
				} else {
					enhance();
				}
			})();
		</script>

		<script is:inline>
			// 给每个 shiki 代码块顶部右侧注入「放大」「复制」按钮
			(function () {
				const FULLSCREEN_SVG =
					'<svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 6 2 2 6 2"></polyline><polyline points="14 6 14 2 10 2"></polyline><polyline points="14 10 14 14 10 14"></polyline><polyline points="2 10 2 14 6 14"></polyline></svg>';
				const EXIT_SVG =
					'<svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 2 6 6 2 6"></polyline><polyline points="10 2 10 6 14 6"></polyline><polyline points="10 14 10 10 14 10"></polyline><polyline points="6 14 6 10 2 10"></polyline></svg>';
				const COPY_SVG =
					'<svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="9" height="11" rx="1.5"></rect><path d="M3 5 H2 V14 H10 V13"></path></svg>';
				const CHECK_SVG =
					'<svg viewBox="0 0 16 16" width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 8 7 12 13 4"></polyline></svg>';

				function init() {
					document.querySelectorAll('.prose pre.astro-code').forEach((pre) => {
						if (pre.dataset.actionsInjected) return;
						pre.dataset.actionsInjected = '1';

						const actions = document.createElement('div');
						actions.className = 'code-actions';
						actions.setAttribute('aria-hidden', 'false');

						const fsBtn = document.createElement('button');
						fsBtn.type = 'button';
						fsBtn.className = 'code-action-btn';
						fsBtn.setAttribute('aria-label', '放大显示');
						fsBtn.title = '放大';
						fsBtn.innerHTML = FULLSCREEN_SVG;

						const copyBtn = document.createElement('button');
						copyBtn.type = 'button';
						copyBtn.className = 'code-action-btn';
						copyBtn.setAttribute('aria-label', '复制代码');
						copyBtn.title = '复制';
						copyBtn.innerHTML = COPY_SVG;

						actions.appendChild(fsBtn);
						actions.appendChild(copyBtn);
						pre.insertBefore(actions, pre.firstChild);

						fsBtn.addEventListener('click', () => {
							// .prose 有 backdrop-filter，会让 position: fixed 相对 .prose 而非
							// viewport（CSS 规范），且 .prose 可能裁剪 → fullscreen pre 会消失。
							// 解决：portal 把 pre 临时移到 body 直接子级，用 anchor comment 标记原位
							if (pre.dataset.fsActive === '1') {
								const anchor = pre._origAnchor;
								if (anchor && anchor.parentNode) {
									anchor.parentNode.insertBefore(pre, anchor);
									anchor.remove();
								}
								pre._origAnchor = null;
								pre.dataset.fsActive = '';
								pre.classList.remove('is-fullscreen');
								document.body.classList.remove('code-fullscreen-open');
								fsBtn.innerHTML = FULLSCREEN_SVG;
								fsBtn.title = '放大';
							} else {
								const anchor = document.createComment(' code-fs-anchor ');
								pre.parentNode.insertBefore(anchor, pre);
								pre._origAnchor = anchor;
								document.body.appendChild(pre);
								pre.dataset.fsActive = '1';
								pre.classList.add('is-fullscreen');
								document.body.classList.add('code-fullscreen-open');
								fsBtn.innerHTML = EXIT_SVG;
								fsBtn.title = '退出放大';
							}
						});

						copyBtn.addEventListener('click', async () => {
							const code = pre.querySelector('code');
							const text = code ? code.innerText : '';
							try {
								await navigator.clipboard.writeText(text);
								copyBtn.classList.add('is-copied');
								copyBtn.innerHTML = CHECK_SVG;
								setTimeout(() => {
									copyBtn.classList.remove('is-copied');
									copyBtn.innerHTML = COPY_SVG;
								}, 1400);
							} catch (e) {
								console.error('[code-copy] clipboard write failed', e);
							}
						});
					});

					// ESC 退出放大（fullscreen pre 已被 portal 到 body 直接子级）
					document.addEventListener('keydown', (e) => {
						if (e.key !== 'Escape') return;
						const fs = document.querySelector('pre.astro-code.is-fullscreen');
						if (!fs) return;
						const btn = fs.querySelector('.code-action-btn[aria-label="放大显示"]');
						if (btn) btn.click(); // 复用 toggle 逻辑（含 portal 回位）
					});
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();

			/* —— 窄屏表格滚动状态：给 .prose table 加 is-scrollable / at-start / at-end，
			   配合 global.css 的 mask-image 实现边缘渐隐提示。
			   原因：iOS Safari 隐藏滚动条，用户不知能滑——渐隐边缘是关键 UX 提示。 */
			(function setupTableScrollHints() {
				function refresh(table) {
					const scrollable = table.scrollWidth > table.clientWidth + 1;
					table.classList.toggle('is-scrollable', scrollable);
					if (!scrollable) {
						table.classList.remove('at-start', 'at-end');
						return;
					}
					const atStart = table.scrollLeft <= 1;
					const atEnd = table.scrollLeft >= table.scrollWidth - table.clientWidth - 1;
					table.classList.toggle('at-start', atStart);
					table.classList.toggle('at-end', atEnd);
				}
				function init() {
					document.querySelectorAll('.prose table').forEach((table) => {
						if (table.dataset.scrollHintInit) return;
						table.dataset.scrollHintInit = '1';
						refresh(table);
						table.addEventListener('scroll', () => refresh(table), { passive: true });
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
				/* viewport 变化也要重算（旋转屏 / 调整窗口） */
				let raf = 0;
				window.addEventListener(
					'resize',
					() => {
						if (raf) return;
						raf = requestAnimationFrame(() => {
							raf = 0;
							document.querySelectorAll('.prose table').forEach(refresh);
						});
					},
					{ passive: true }
				);
			})();
		</script>
	</body>
</html>
