---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`搜索 · ${SITE_TITLE}`} description="搜索博客内容" />
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/@pagefind/default-ui@latest/css/ui.css"
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>搜索</h1>
			<p class="hint">输入关键词搜索所有博文。按 <kbd>/</kbd> 聚焦搜索框，<kbd>Esc</kbd> 清空。</p>
			<div id="search" class="pagefind-wrap"></div>
		</main>
		<Footer />
		<script
			is:inline
			src="https://cdn.jsdelivr.net/npm/@pagefind/default-ui@latest/npm_dist/mjs/ui-core.mjs"
			type="module"></script>
		<script is:inline>
			window.addEventListener('DOMContentLoaded', async () => {
				const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
				new PagefindUI({
					element: '#search',
					showSubResults: true,
					showImages: true,
					translations: {
						placeholder: '搜索博文...',
						clear_search: '清空',
						load_more: '加载更多',
						search_label: '搜索',
						filters_label: '过滤',
						zero_results: '没有找到关于「[SEARCH_TERM]」的内容',
						many_results: '找到 [COUNT] 条关于「[SEARCH_TERM]」的结果',
						one_result: '找到 1 条关于「[SEARCH_TERM]」的结果',
						alt_search:
							'没有「[SEARCH_TERM]」的结果，显示「[DIFFERENT_TERM]」的相关结果',
						search_suggestion: '没有「[SEARCH_TERM]」的结果，试试这些关键词：',
						searching: '正在搜索「[SEARCH_TERM]」...',
					},
				});
			});

			document.addEventListener('keydown', (e) => {
				const tag = e.target.tagName;
				if (e.key === '/' && tag !== 'INPUT' && tag !== 'TEXTAREA') {
					e.preventDefault();
					const input = document.querySelector('.pagefind-ui__search-input');
					input?.focus();
				}
				if (e.key === 'Escape') {
					const input = document.querySelector('.pagefind-ui__search-input');
					if (input && input === document.activeElement) input.value = '';
				}
			});
		</script>
		<style>
			h1 {
				margin-bottom: 0.2em;
			}
			.hint {
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			kbd {
				padding: 0.1em 0.4em;
				font-family: monospace;
				background: rgba(0, 0, 0, 0.06);
				border: 1px solid rgba(0, 0, 0, 0.1);
				border-radius: 4px;
				font-size: 0.9em;
			}
			.pagefind-wrap {
				margin-top: 1em;
			}
			:global(.pagefind-ui__search-input) {
				background: rgba(255, 255, 255, 0.7);
			}
			:global(.pagefind-ui__result) {
				background: rgba(255, 255, 255, 0.4);
				border-radius: 12px;
				padding: 1em;
				margin-bottom: 0.8em;
			}
		</style>
	</body>
</html>
