---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>👋 你好，欢迎来到我的小宇宙</h1>
			<p>
				这里是 <strong>WizardHeHeJun's Notes</strong>——一个用来放项目分享、技术笔记和碎碎念的地方。
			</p>
			<p>
				去 <a href="/blog">博客</a> 看看最近写了什么，或者去 <a href="/about">关于</a> 了解一下我是谁。
			</p>
			<p>
				如果你恰好读到了什么有用的内容，那就是我写这些字最满意的回报啦。
			</p>
		</main>
		<Footer />
	</body>
</html>
