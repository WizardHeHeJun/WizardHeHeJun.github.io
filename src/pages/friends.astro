---
import BaseHead from '../components/BaseHead.astro';
import Comments from '../components/Comments.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
import friendsRaw from '../data/friends.json';
import ogCacheRaw from '../data/og-cache.json';

type Friend = {
	name: string;
	url: string;
	description?: string;
	avatar?: string;
	accent?: string; // hex (e.g. '#4a90e2')；不填则用默认彩色斜渐变
};
type OgEntry = {
	url: string;
	image?: string;
	title?: string;
	description?: string;
	favicon?: string;
	status: 'ok' | 'partial' | 'failed';
};

const friends = friendsRaw as Friend[];
const ogCache = ogCacheRaw as Record<string, OgEntry>;

type Thumb =
	| { kind: 'image'; src: string }
	| { kind: 'favicon'; src: string }
	| { kind: 'letter'; src: string };

function pickThumb(f: Friend): Thumb {
	if (f.avatar) return { kind: 'image', src: f.avatar };
	const entry = ogCache[f.url];
	if (entry?.image) return { kind: 'image', src: entry.image };
	if (entry?.favicon) return { kind: 'favicon', src: entry.favicon };
	return { kind: 'letter', src: (f.name?.[0] ?? '?').toUpperCase() };
}

function pickDesc(f: Friend): string {
	return f.description || ogCache[f.url]?.description || '';
}
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`友链 · ${SITE_TITLE}`} description="一些值得关注的博客和小宇宙" />
	</head>
	<body>
		<Header />
		<main>
			<h1>友链</h1>
			<p class="hint">一些值得关注的博客和小宇宙。想换链直接在下方评论区留言哦～</p>

			{
				friends.length === 0 ? (
					<p class="empty">还没有友链。等你把第一个朋友加进来 ✨</p>
				) : (
					<ul class="friends-grid">
						{friends.map((f) => {
							const thumb = pickThumb(f);
							const desc = pickDesc(f);
							// 有 accent 时，色块/名字色/发光描边都用主题色派生（color-mix 算明暗变体）
							const cardStyle = f.accent
								? `--card-accent: ${f.accent};` +
								  `--card-strip-bg: linear-gradient(135deg, ` +
								  `color-mix(in srgb, ${f.accent} 55%, white), ` +
								  `${f.accent}, ` +
								  `color-mix(in srgb, ${f.accent} 65%, white));`
								: '';
							return (
								<li>
									<a
										href={f.url}
										target="_blank"
										rel="noopener"
										class="friend-card"
										style={cardStyle}
									>
										<div class="card-inner">
											<div class="card-strip" aria-hidden="true" />
											<div class="avatar-wrap">
												{thumb.kind === 'image' || thumb.kind === 'favicon' ? (
													<img class={`avatar ${thumb.kind}`} src={thumb.src} alt={f.name} loading="lazy" />
												) : (
													<div class="avatar letter" aria-hidden="true">{thumb.src}</div>
												)}
											</div>
											<div class="info">
												<h3>{f.name}</h3>
												{desc && <p>{desc}</p>}
											</div>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				)
			}

			<section class="apply">
				<h2>申请友链</h2>
				<p>欢迎志同道合的朋友交换链接。本站信息：</p>
				<pre><code>{`名称：WizardHeHeJun's Notes
地址：https://wizardhehejun.github.io
头像：https://wizardhehejun.github.io/favicon-192.png
描述：项目分享、技术笔记，和一些不想被时间冲走的碎碎念。`}</code></pre>
				<p>把以上信息和你的博客信息发给我（GitHub Issue 或 X 私信都行）。</p>
			</section>

			<div class="comments-wrap">
				<Comments
					mapping="specific"
					term="page-friends"
					title="💬 想换链？或者只是路过打个招呼？"
					hint="把申请信息留在这里就好——「悄悄告诉你哦，我每条都会看的呢」"
				/>
			</div>
		</main>
		<Footer />
		<style>
			main {
				width: min(960px, 100% - 2em);
			}
			h1 {
				margin-bottom: 0.2em;
			}
			.hint {
				color: rgb(var(--gray));
				margin-bottom: 1.5em;
			}
			.empty {
				text-align: center;
				color: rgb(var(--gray));
				padding: 2em;
				background: rgba(255, 255, 255, 0.4);
				border-radius: 12px;
			}
			.friends-grid {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				/* 两列优先：220px minmax；窄屏自动单列 */
				grid-template-columns: repeat(auto-fill, minmax(min(220px, 100%), 1fr));
				gap: 1em;
				perspective: 800px;
			}
			.friend-card {
				position: relative;
				display: block;
				padding: 10px;
				background: rgba(255, 255, 255, 0.55);
				border: 1px solid rgba(255, 255, 255, 0.5);
				border-radius: 18px;
				text-decoration: none;
				color: rgb(var(--gray-dark));
				box-shadow: 0 4px 16px rgba(31, 38, 135, 0.08);
				transform: perspective(800px)
					rotateX(var(--tilt-x, 0deg))
					rotateY(var(--tilt-y, 0deg))
					translateY(var(--lift, 0));
				transition:
					transform 0.25s cubic-bezier(0.2, 0.7, 0.3, 1),
					box-shadow 0.25s ease,
					background 0.2s ease;
				transform-style: preserve-3d;
				will-change: transform;
			}
			.friend-card:hover {
				background: rgba(255, 255, 255, 0.78);
				box-shadow: 0 18px 44px rgba(31, 38, 135, 0.22);
				--lift: -5px;
			}
			.card-inner {
				position: relative;
				border-radius: 10px;
				overflow: hidden;
				background: rgba(255, 255, 255, 0.5);
				box-shadow: 0 2px 8px rgba(31, 38, 135, 0.08);
				transition:
					box-shadow 0.3s ease,
					filter 0.3s ease;
			}
			.friend-card:hover .card-inner {
				box-shadow:
					0 0 32px 10px color-mix(in srgb, var(--card-accent, #4a7fff) 28%, transparent),
					0 0 70px 22px color-mix(in srgb, var(--card-accent, #4a7fff) 15%, transparent),
					0 8px 22px rgba(31, 38, 135, 0.2);
			}
			.card-strip {
				height: 80px;
				background: var(
					--card-strip-bg,
					linear-gradient(
						135deg,
						rgba(102, 204, 255, 0.7),
						rgba(74, 127, 255, 0.55) 45%,
						rgba(255, 144, 192, 0.7)
					)
				);
				position: relative;
			}
			.card-strip::after {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(
					ellipse at 30% 30%,
					rgba(255, 255, 255, 0.35),
					transparent 65%
				);
			}
			.avatar-wrap {
				position: relative;
				height: 0;
				display: flex;
				justify-content: center;
			}
			.avatar {
				position: absolute;
				top: -32px;
				width: 64px;
				height: 64px;
				border-radius: 50%;
				object-fit: cover;
				background: #fff;
				border: 3px solid #fff;
				box-shadow: 0 4px 12px rgba(31, 38, 135, 0.15);
				display: flex;
				align-items: center;
				justify-content: center;
				transform: translateZ(0);
				transition:
					transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1),
					box-shadow 0.25s ease;
				will-change: transform;
			}
			.friend-card:hover .avatar {
				transform: translateZ(40px) scale(1.14);
				box-shadow: 0 12px 28px rgba(31, 38, 135, 0.25);
			}
			.avatar.favicon {
				padding: 10px;
				background: #fff;
			}
			.avatar.letter {
				background: linear-gradient(135deg, rgba(35, 55, 255, 0.15), rgba(255, 144, 192, 0.25));
				color: var(--accent);
				font-size: 1.4em;
				font-weight: 700;
			}
			.info {
				padding: 2.6em 0.9em 1em;
				text-align: center;
			}
			.info h3 {
				margin: 0 0 0.25em;
				font-size: 1.05em;
				font-weight: 600;
				color: #000;
				letter-spacing: 0.02em;
				transition: color 0.25s ease;
			}
			.friend-card:hover .info h3 {
				color: var(--card-accent, #4a7fff);
			}
			.info .subtitle {
				margin: 0 0 0.5em;
				font-size: 0.72em;
				color: rgb(var(--gray));
				letter-spacing: 0.12em;
				text-transform: uppercase;
				opacity: 0.7;
			}
			.info p {
				margin: 0;
				font-size: 0.82em;
				color: #8a9bb5;
				line-height: 1.45;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			@media (prefers-reduced-motion: reduce) {
				.friend-card,
				.friend-card:hover .avatar {
					transition: background 0.2s ease;
					transform: none !important;
				}
			}
			.apply {
				margin-top: 3em;
				padding-top: 1.5em;
				border-top: 1px dashed rgba(0, 0, 0, 0.1);
			}
			.apply h2 {
				font-size: 1.3em;
			}
			.apply pre {
				padding: 1em;
				background: rgba(255, 255, 255, 0.4);
				border-radius: 8px;
				font-size: 0.85em;
				overflow-x: auto;
			}
			.comments-wrap {
				margin-top: 2em;
			}

			/* —— 大屏：放宽内容范围 —— */
			@media (min-width: 1400px) {
				main {
					width: min(1200px, 100% - 4em);
				}
			}
			@media (min-width: 1800px) {
				main {
					width: min(1360px, 100% - 6em);
				}
			}
		</style>

		<script is:inline>
			(function () {
				function init() {
					// 触屏 / reduced-motion 跳过 tilt（CLAUDE.md §13）
					if (window.matchMedia('(hover: none), (pointer: coarse)').matches) return;
					if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

					const MAX_TILT = 20; // 度
					document.querySelectorAll('.friend-card').forEach((card) => {
						let raf = 0;
						const onMove = (e) => {
							if (raf) return;
							raf = requestAnimationFrame(() => {
								const rect = card.getBoundingClientRect();
								const x = (e.clientX - rect.left) / rect.width - 0.5;
								const y = (e.clientY - rect.top) / rect.height - 0.5;
								card.style.setProperty('--tilt-x', `${(-y * MAX_TILT).toFixed(2)}deg`);
								card.style.setProperty('--tilt-y', `${(x * MAX_TILT).toFixed(2)}deg`);
								raf = 0;
							});
						};
						const onLeave = () => {
							card.style.removeProperty('--tilt-x');
							card.style.removeProperty('--tilt-y');
						};
						card.addEventListener('mousemove', onMove);
						card.addEventListener('mouseleave', onLeave);
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();
		</script>
	</body>
</html>
