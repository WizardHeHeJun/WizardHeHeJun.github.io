---
import { GISCUS } from '../consts';

interface Props {
	mapping?: 'pathname' | 'specific' | 'title' | 'url';
	term?: string;
	title?: string;
	hint?: string;
}

const {
	mapping = 'pathname',
	term,
	title = '💬 留下你的想法～',
	hint = '用 GitHub 账号登录，留个表情或写两句都好——「悄悄告诉你哦，我每条都会看的呢」',
} = Astro.props;

const dataTerm = mapping === 'specific' ? term : undefined;

// giscus 自定义主题需要 HTTPS 绝对 URL（iframe 跨域加载）
// dev 模式下 localhost 是 HTTP，加载到 HTTPS 的 giscus iframe 里会被 mixed-content 拦截
// 所以 dev 回退到内置 `light`，仅在 build/部署后启用自定义主题
// 加 build 时间戳作为 cache buster——每次 build 都是新 URL，giscus iframe 不会缓存旧版 CSS
const siteOrigin = (Astro.site?.toString() || 'https://wizardhehejun.github.io/').replace(/\/$/, '');
const themeVersion = Math.floor(Date.now() / 1000);
const giscusTheme = import.meta.env.DEV
	? 'light'
	: `${siteOrigin}/giscus-theme.css?v=${themeVersion}`;
---

<section class="comments-card">
	<h2 class="comments-title">{title}</h2>
	<p class="comments-hint">{hint}</p>
	<div class="giscus-mount">
		<script
			is:inline
			src="https://giscus.app/client.js"
			data-repo={GISCUS.repo}
			data-repo-id={GISCUS.repoId}
			data-category={GISCUS.category}
			data-category-id={GISCUS.categoryId}
			data-mapping={mapping}
			data-term={dataTerm}
			data-strict="0"
			data-reactions-enabled="1"
			data-emit-metadata="0"
			data-input-position="bottom"
			data-theme={giscusTheme}
			data-lang="zh-CN"
			data-loading="lazy"
			crossorigin="anonymous"
			async></script>
	</div>
</section>

<style>
	.comments-card {
		width: 100%;
		padding: 1.8em 2em;
		/* 调低 alpha + 减弱 blur，让背景图的水色调子在所有滚动位置都能透出来，
		   不会因为页面位置不同（about 动态背景 vs friends 偏白段）而显得轻重不一 */
		background: rgba(255, 255, 255, 0.28);
		backdrop-filter: blur(12px) saturate(160%);
		-webkit-backdrop-filter: blur(12px) saturate(160%);
		border: 1px solid rgba(255, 255, 255, 0.4);
		border-radius: 18px;
		box-shadow: 0 4px 18px rgba(31, 38, 135, 0.08);
		box-sizing: border-box;
	}
	.comments-title {
		margin: 0 0 0.4em;
		font-size: 1.3em;
		color: rgb(var(--gray-dark));
	}
	.comments-hint {
		margin: 0 0 1.2em;
		color: rgb(var(--gray));
		font-size: 0.9em;
		line-height: 1.6;
	}
	.giscus-mount {
		min-height: 150px;
	}
	.giscus-mount :global(.giscus-frame) {
		width: 100%;
		border: none;
		color-scheme: light;
	}
	@media (max-width: 640px) {
		.comments-card {
			padding: 1.4em 1.2em;
		}
	}
</style>
